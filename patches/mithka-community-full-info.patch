+void CommunityManager::get_community_full_info(
+    CommunityId community_id, Promise<td_api::object_ptr<td_api::communityFullInfo>> &&promise) {
+  if (!have_accessible_community(community_id)) {
+    return promise.set_error(400, "Community not found");
+  }
+  auto input_community = get_input_community(community_id);
+  if (input_community == nullptr) {
+    return promise.set_error(400, "Community not found");
+  }
+  td_->create_handler<GetCommunityFullInfoQuery>(std::move(promise))->send(std::move(input_community));
+}
