+class GetCommunityFullInfoQuery final : public Td::ResultHandler {
+  Promise<td_api::object_ptr<td_api::communityFullInfo>> promise_;
+
+ public:
+  explicit GetCommunityFullInfoQuery(Promise<td_api::object_ptr<td_api::communityFullInfo>> &&promise)
+      : promise_(std::move(promise)) {
+  }
+
+  void send(telegram_api::object_ptr<telegram_api::InputChannel> &&input_community) {
+    CHECK(input_community != nullptr);
+    send_query(G()->net_query_creator().create(telegram_api::channels_getFullChannel(std::move(input_community))));
+  }
+
+  void on_result(BufferSlice packet) final {
+    auto result_ptr = fetch_result<telegram_api::channels_getFullChannel>(packet);
+    if (result_ptr.is_error()) {
+      return on_error(result_ptr.move_as_error());
+    }
+
+    auto result = result_ptr.move_as_ok();
+    td_->user_manager_->on_get_users(std::move(result->users_), "GetCommunityFullInfoQuery");
+    td_->chat_manager_->on_get_chats(std::move(result->chats_), "GetCommunityFullInfoQuery");
+    if (result->full_chat_->get_id() != telegram_api::communityFull::ID) {
+      return promise_.set_error(500, "Unexpected community full info");
+    }
+
+    auto community_full = move_tl_object_as<telegram_api::communityFull>(result->full_chat_);
+    vector<td_api::object_ptr<td_api::communityPeerInfo>> peers;
+    peers.reserve(community_full->linked_peers_.size());
+    for (auto &peer : community_full->linked_peers_) {
+      auto dialog_id = DialogId(peer->peer_);
+      if (!dialog_id.is_valid()) {
+        LOG(ERROR) << "Receive invalid community peer";
+        continue;
+      }
+      td_->dialog_manager_->force_create_dialog(dialog_id, "GetCommunityFullInfoQuery", true);
+      auto has_visibility = (peer->flags_ & 1) != 0;
+      peers.push_back(td_api::make_object<td_api::communityPeerInfo>(
+          td_->dialog_manager_->get_chat_id_object(dialog_id, "communityPeerInfo"), peer->can_view_history_,
+          has_visibility, peer->visible_));
+    }
+    promise_.set_value(td_api::make_object<td_api::communityFullInfo>(std::move(peers)));
+  }
+
+  void on_error(Status status) final {
+    promise_.set_error(std::move(status));
+  }
+};
