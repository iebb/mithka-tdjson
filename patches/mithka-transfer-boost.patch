+std::atomic<int32> mithka_upload_parallelism{0};
+
+int32 normalize_mithka_part_size(int32 part_size, int32 max_part_size) {
+  if (part_size <= 0) {
+    return 0;
+  }
+  int32 result = 4 << 10;
+  while (result < max_part_size && result <= part_size / 2) {
+    result *= 2;
+  }
+  return result;
+}
+
+int32 normalize_mithka_parallelism(int32 parallelism) {
+  return parallelism <= 0 ? 0 : td::min(parallelism, 24);
+}
