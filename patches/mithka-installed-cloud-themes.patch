+class GetInstalledCloudThemesQuery final : public Td::ResultHandler {
+  Promise<td_api::object_ptr<td_api::installedCloudThemes>> promise_;
+
+ public:
+  explicit GetInstalledCloudThemesQuery(Promise<td_api::object_ptr<td_api::installedCloudThemes>> &&promise)
+      : promise_(std::move(promise)) {
+  }
+
+  void send(const string &theme_format) {
+    send_query(G()->net_query_creator().create(telegram_api::account_getThemes(theme_format, 0)));
+  }
+
+  void on_result(BufferSlice packet) final {
+    auto result_ptr = fetch_result<telegram_api::account_getThemes>(packet);
+    if (result_ptr.is_error()) {
+      return on_error(result_ptr.move_as_error());
+    }
+    auto themes_ptr = result_ptr.move_as_ok();
+    auto result = td_api::make_object<td_api::installedCloudThemes>();
+    if (themes_ptr->get_id() == telegram_api::account_themes::ID) {
+      auto themes = telegram_api::move_object_as<telegram_api::account_themes>(themes_ptr);
+      for (auto &theme : themes->themes_) {
+        if (theme->for_chat_ || theme->slug_.empty()) {
+          continue;
+        }
+        result->themes_.push_back(
+            td_api::make_object<td_api::installedCloudTheme>(std::move(theme->slug_), std::move(theme->title_)));
+      }
+    }
+    promise_.set_value(std::move(result));
+  }
+
+  void on_error(Status status) final {
+    promise_.set_error(std::move(status));
+  }
+};
