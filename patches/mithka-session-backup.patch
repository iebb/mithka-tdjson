+/**
+ * Exports a Pyrogram-compatible TDLib session string using format
+ * >BI?256sQ? (dc_id, api_id, test_mode, auth_key, user_id, is_bot).
+ *
+ * This is a Mithka-private extension. It is intentionally outside the public
+ * TDLib JSON API and is used only for local account session backup.
+ *
+ * \param[in] source_binlog_path Path to the source td.binlog.
+ * \param[in] api_id Telegram client API id to store in the session string.
+ * \param[in] test_mode Whether the session uses Telegram test DCs.
+ * \return Session string on success; NULL on failure. Use td_mithka_last_error for details.
+ */
+TDJSON_EXPORT const char *td_mithka_export_session_string(const char *source_binlog_path, int api_id, int test_mode,
+                                                          long long user_id);
+
+/**
+ * Imports a Pyrogram-compatible TDLib session string into a fresh TDLib binlog.
+ *
+ * \param[in] session_string Session string using format >BI?256sQ?.
+ * \param[in] destination_binlog_path Path where td.binlog will be written.
+ * \return 0 on success; -1 on failure. Use td_mithka_last_error for details.
+ */
+TDJSON_EXPORT int td_mithka_import_session_string(const char *session_string, const char *destination_binlog_path);
+
+/**
+ * Returns the last Mithka-private TDLib extension error for the current thread.
+ * The returned pointer is valid until the next call to a TDLib JSON or Mithka
+ * extension function on the same thread.
+ */
+TDJSON_EXPORT const char *td_mithka_last_error();
